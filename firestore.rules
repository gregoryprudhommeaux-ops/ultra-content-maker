rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isLinkedToAccount(ownerId, accountId) {
      return request.auth != null
        && userDoc().linkedWorkspace != null
        && userDoc().linkedWorkspace.ownerId == ownerId
        && userDoc().linkedWorkspace.accountId == accountId;
    }

    function isAgencyManagerOf(clientUserId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(clientUserId))
        && get(/databases/$(database)/documents/users/$(clientUserId)).data.managedBy != null
        && get(/databases/$(database)/documents/users/$(clientUserId)).data.managedBy.adminUid == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId || isAgencyManagerOf(userId)
      );
      allow write: if request.auth != null && request.auth.uid == userId;

      match /accounts/{accountId} {
        allow read: if request.auth != null && (
          request.auth.uid == userId || isLinkedToAccount(userId, accountId) || isAgencyManagerOf(userId)
        );
        allow write: if request.auth != null && (
          request.auth.uid == userId || isLinkedToAccount(userId, accountId) || isAgencyManagerOf(userId)
        );

        match /{document=**} {
          allow read, write: if request.auth != null && (
            request.auth.uid == userId || isLinkedToAccount(userId, accountId) || isAgencyManagerOf(userId)
          );
        }
      }

      match /{document=**} {
        allow read, write: if request.auth != null && (
          request.auth.uid == userId || isAgencyManagerOf(userId)
        );
      }
    }

    match /accountInvites/{token} {
      allow read, write: if false;
    }
  }
}
